# Per-machine work hosts (internal domains kept out of public dotfiles).
Include ~/.ssh/config.work

Host codeberg.org
	User git
	IdentityFile ~/.ssh/codeberg.pub
	IdentitiesOnly yes

Host github.com
	User git
	IdentityFile ~/.ssh/github.pub
	IdentitiesOnly yes

# OS-specific 1Password SSH agent. Match exec runs the test command;
# the IdentityAgent line only applies when the matching socket exists.
Match host * exec "test -S '%d/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock'"
	IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

Match host * exec "test -S %d/.1password/agent.sock"
	IdentityAgent ~/.1password/agent.sock
